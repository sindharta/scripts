alias gfmain='git fetch origin main:main'
alias gfmaster='git fetch origin master:master'
alias gftrunk='git fetch origin trunk:trunk'
alias gfmain-co='git fetch origin main:main &6 git checkout main'
alias gfmaster-co='git fetch origin master:master &6 git checkout master'
alias gftrunk=-co'git fetch origin trunk:trunk && git checkout trunk'


alias gpmain='git pull --rebase origin main'
alias gpmaster='git pull --rebase origin master'
alias gptrunk='git pull --rebase origin trunk'

alias gp='git pull'
alias gp-r='git pull --rebase'
alias gps='git push'
alias gps-u='git push -u'
alias gco='git checkout'
alias gco-b='git checkout -b'
alias git-delete-pushed-branches='git branch | grep -Ev "(^\*|^\+|master|main|dev)" | xargs --no-run-if-empty git branch -d'
alias grprune='git remote prune origin'



